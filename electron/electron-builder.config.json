{
  "appId": "com.sp.services",
  "directories": {
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "publish": null,
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": "nsis",
    "icon": "assets/icons/icons/win/win/icon.ico"
  },
  "mac": {
    "category": "your.app.category.type",
    "target": "dmg"
  }
}